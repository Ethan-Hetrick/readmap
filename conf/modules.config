/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: FASTP {
        ext.args = '--trim_poly_g'
    }

    withName: MINIMAP2_ALIGN {
        ext.args = '-x sr'
    }

    withName: SAMTOOLS_SORMADUP {
        ext.args6 = '-q 20 -F UNMAP,SECONDARY,SUPPLEMENTARY,QCFAIL,DUP'
    }

    withName: STACKS_REFMAP {
        ext.gstacks_args     = ''
        ext.populations_args = {
            [
                '--vcf',
                '--ordered-export',
                '--write-random-snp',
                params.stacks_populations_p != null ? "-p ${params.stacks_populations_p}" : '',
                params.stacks_populations_r != null ? "-r ${params.stacks_populations_r}" : '',
                params.stacks_populations_min_mac != null ? "--min-mac ${params.stacks_populations_min_mac}" : '',
                params.stacks_populations_max_obs_het != null ? "--max-obs-het ${params.stacks_populations_max_obs_het}" : '',
            ].join(' ').trim()
        }
    }

    withName: BCFTOOLS_INDEX {
        ext.args = '--tbi'
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'KRAKEN2_KRAKEN2' {
        ext.args = '--memory-mapping --quick'
        memory = { 300.GB }
        cpus = { 12 }
    }

}
